generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar(100)
  email        String         @unique @db.VarChar(100)
  passwordHash String         @map("password_hash") @db.VarChar(255)
  upiId        String?        @map("upi_id") @db.VarChar(100)
  qrImageUrl   String?        @map("qr_image_url")
  createdAt    DateTime       @default(now()) @map("created_at")

  sessions     Session[]
  batches      Batch[]
  activityLogs ActivityLog[]

  @@map("admins")
}

model Batch {
  id        Int      @id @default(autoincrement())
  adminId   Int      @map("admin_id")
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  admin    Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([adminId])
  @@map("batches")
}

model Session {
  id          Int           @id @default(autoincrement())
  adminId     Int           @map("admin_id")
  batchId     Int?          @map("batch_id")
  title       String        @db.VarChar(255)
  amount      Decimal       @db.Decimal(10, 2)
  date        DateTime      @default(dbgenerated("CURRENT_DATE")) @db.Date
  status      SessionStatus @default(active)
  publicToken String        @unique @map("public_token") @db.VarChar(100)
  createdAt   DateTime      @default(now()) @map("created_at")

  admin        Admin         @relation(fields: [adminId], references: [id], onDelete: Cascade)
  batch        Batch?        @relation(fields: [batchId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@index([adminId])
  @@index([batchId])
  @@index([publicToken])
  @@map("sessions")
}

model Transaction {
  id              Int      @id @default(autoincrement())
  sessionId       Int      @map("session_id")
  payerName       String   @map("payer_name") @db.VarChar(100)
  studentRollNo   String?  @map("student_roll_no") @db.VarChar(50)
  amount          Decimal  @db.Decimal(10, 2)
  utr             String?  @unique @db.VarChar(100)
  paymentTime     DateTime @default(now()) @map("payment_time")
  verified        Boolean  @default(false)
  rejected        Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([utr])
  @@index([studentRollNo])
  @@map("transactions")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  adminId   Int      @map("admin_id")
  action    String   @db.VarChar(255)
  timestamp DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

enum SessionStatus {
  active
  closed
}
